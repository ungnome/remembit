{
  "name": "remembit",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky install",
    "dev": "concurrently -n supabase,vite pnpm:dev:start:supabase pnpm:dev:start:web && supabase stop",
    "dev:start:supabase": "supabase start && ./scripts/init-env.sh",
    "dev:start:web": "vite --mode dev-web",
    "dev:start:ios": "pnpm run build --mode dev-ios --outDir dist-dev-ios && CAP_PLAT=dev-ios cap run ios",
    "dev:start:android": "pnpm run build --mode dev-android --outDir dist-dev-android && CAP_PLAT=dev-android cap run android",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue,.ts --fix src",
    "capsync": "pnpm run build --mode development && pnpm exec cap sync",
    "release": "semantic-release"
  },
  "dependencies": {
    "@capacitor/android": "^4.3.0",
    "@capacitor/app": "^4.0.1",
    "@capacitor/core": "^4.3.0",
    "@capacitor/haptics": "^4.0.1",
    "@capacitor/ios": "^4.3.0",
    "@capacitor/keyboard": "^4.0.1",
    "@capacitor/status-bar": "^4.0.1",
    "@ionic/vue": "^6.3.0",
    "@ionic/vue-router": "^6.3.0",
    "@supabase/supabase-js": "^1.35.7",
    "just-clone": "^6.1.1",
    "just-merge": "^3.1.1",
    "just-pick": "^4.1.1",
    "pinia": "^2.0.23",
    "vee-validate": "^4.6.10",
    "vue": "^3.2.40",
    "vue-router": "^4.1.5",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^4.3.0",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@semantic-release/changelog": "^6.0.1",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.1.2",
    "@types/node": "*",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "@vitejs/plugin-vue": "^3.1.2",
    "concurrently": "^7.4.0",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-vue": "^9.6.0",
    "husky": "^8.0.1",
    "jest": "^29.1.2",
    "onchange": "^7.1.0",
    "prettier": "^2.7.1",
    "semantic-release": "^19.0.5",
    "ts-jest": "^29.0.3",
    "typescript": "^4.8.4",
    "vite": "^3.1.6",
    "vite-plugin-pwa": "^0.13.1",
    "vue-tsc": "^1.0.1"
  }
}
